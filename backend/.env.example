NODE_ENV=development
PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/ngo-vms
JWT_SECRET=replace_with_a_secure_secret
ACCESS_TOKEN_SECRET=replace_with_a_different_access_secret
REFRESH_TOKEN_SECRET=replace_with_a_different_refresh_secret
FRONTEND_URL=http://localhost:5173
LOG_LEVEL=debug

# Rate limiting (milliseconds)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
AUTH_RATE_LIMIT_MAX=100
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=7
EMAIL_VERIFICATION_TTL_HOURS=24
PASSWORD_RESET_TTL_MINUTES=30
REFRESH_TOKEN_MAX_SESSIONS=5
REFRESH_COOKIE_NAME=ngo_vms_refresh
CSRF_COOKIE_NAME=ngo_vms_csrf
